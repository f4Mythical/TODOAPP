<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <TextView
        android:id="@+id/tvMowTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mów"
        android:textColor="@color/brown_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="48dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/btnMic"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:src="@drawable/ic_mic"
        android:background="@drawable/profile_avatar_bg"
        android:backgroundTint="@color/brown_primary"
        app:tint="@color/cream"
        android:layout_marginBottom="120dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvMowStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Naciśnij mikrofon i powiedz co zaplanować"
        android:textColor="@color/brown_light"
        android:textSize="13sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginTop="24dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/btnMic"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:id="@+id/progressMow"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:indeterminateTint="@color/brown_primary"
        android:visibility="gone"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvMowStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>